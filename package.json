{
  "name": "autoskills-sh",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "og": "node scripts/generate-og.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt --write .",
    "fmt:staged": "oxfmt --write --no-error-on-unmatched-pattern",
    "fmt:check": "oxfmt --check .",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.4",
    "astro": "6.1.9",
    "geist": "1.7.0",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
